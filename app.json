{
  "expo": {
    "name": "Parcel Safe",
    "slug": "ParcelSafeApp",
    "scheme": "parcelsafe",
    "version": "1.0.1",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/f311506b-aeb6-4cf8-9847-9edf898eac0d",
      "fallbackToCacheTimeout": 0
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "android": {
      "package": "com.parcel.safe",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": false,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "WAKE_LOCK",
        "USE_FULL_SCREEN_INTENT",
        "REQUEST_IGNORE_BATTERY_OPTIMIZATIONS",
        "POST_NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      "@react-native-google-signin/google-signin",
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsImpl": "mapbox"
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#FF6B00",
          "mode": "production"
        }
      ],
      [
        "@react-native-firebase/app"
      ],
      [
        "@react-native-firebase/messaging",
        {
          "autolinkEnabled": true
        }
      ],
      "./scripts/withAndroidManifestHelpers.js",
      "./scripts/withAndroidKotlin.js",
      "expo-font",
      "expo-updates",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.1.20",
            "compileSdkVersion": 35,
            "targetSdkVersion": 34,
            "buildToolsVersion": "35.0.0"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Parcel Safe to access your photos to attach proof of delivery.",
          "cameraPermission": "Allow Parcel Safe to access your camera to take proof of delivery photos."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "f311506b-aeb6-4cf8-9847-9edf898eac0d"
      }
    }
  }
}